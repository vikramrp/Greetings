{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "logoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "name"]
    },
    "Template": {
      "title": "Template",
      "description": "Poster template information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "imageURL": { "type": "string" },
        "placeholders": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "image"] },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "width": { "type": "number" },
              "height": { "type": "number" },
              "fontSize": { "type": "number" },
              "color": { "type": "string" },
              "label": { "type": "string" }
            }
          }
        }
      },
      "required": ["title", "category", "imageURL"]
    },
    "Poster": {
      "title": "Poster",
      "description": "Generated poster information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "templateId": { "type": "string" },
        "finalImageURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "templateId", "finalImageURL"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Available templates"
    },
    "/posters/{posterId}": {
      "schema": "Poster",
      "description": "User generated posters"
    }
  }
}
